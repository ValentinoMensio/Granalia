# App
GRANALIA_ENV=production
GRANALIA_LOG_LEVEL=INFO
GRANALIA_LOG_JSON=true
GRANALIA_ALLOWED_ORIGINS=https://granalia.example.com
GRANALIA_DOMAIN=granalia.example.com
GRANALIA_CADDY_SITE=:80
GRANALIA_API_UPSTREAM=api:8000
GRANALIA_LOCAL_CADDY_PORT=8088
GRANALIA_LOCAL_POSTGRES_PORT=5433
GRANALIA_SECURE_COOKIES=true

# Secrets
GRANALIA_SESSION_SECRET=replace-with-32-bytes-minimum-secret
GRANALIA_AUTH_USERNAME=admin
GRANALIA_AUTH_ROLE=admin
GRANALIA_AUTH_PASSWORD_HASH=
GRANALIA_AUTH_PASSWORD=
GRANALIA_INVOICE_AUTH_PASSWORD_HASH=

# ARCA / Factura electronica
GRANALIA_ARCA_ENABLED=false
GRANALIA_ARCA_ENV=homologacion
GRANALIA_ARCA_CUIT=
GRANALIA_ARCA_POINT_OF_SALE=
GRANALIA_ARCA_CERT_PATH=/run/secrets/arca-cert.crt
GRANALIA_ARCA_KEY_PATH=/run/secrets/arca-private.key
GRANALIA_ARCA_KEY_PASSWORD=
GRANALIA_ARCA_DRY_RUN=true
GRANALIA_ARCA_MARK_AUTHORIZED=false
GRANALIA_ARCA_ALLOW_MANUAL_FISCAL_CUSTOMER=false
GRANALIA_ARCA_TIMEOUT_SECONDS=30
GRANALIA_ARCA_TOKEN_CACHE_PATH=/tmp/granalia-arca-wsaa-token.json
GRANALIA_ARCA_RECEIVER_IVA_CONDITION_ID=1
GRANALIA_ARCA_PADRON_SERVICE=ws_sr_constancia_inscripcion

# Database
POSTGRES_DB=granalia
POSTGRES_USER=granalia
POSTGRES_PASSWORD=replace-with-strong-db-password
GRANALIA_POSTGRES_URL=postgresql+psycopg://granalia:replace-with-strong-db-password@postgres:5432/granalia

# Backups
GRANALIA_BACKUP_DIR=./backups
GRANALIA_BACKUP_RETENTION_DAYS=14
